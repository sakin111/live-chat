    "@nestjs/websockets": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "drizzle-orm": "^0.30.0",
    "pg": "^8.11.0",
    "ioredis": "^5.3.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "socket.io": "^4.7.0",
    "class-validator": "^0.14.0",
    "class-transformer": "^0.5.0",
    "nanoid": "^3.3.7",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "@nestjs/cli": "^10.0.0"
  },
  "devDependencies": {
    "@nestjs/schematics": "^10.0.0",
